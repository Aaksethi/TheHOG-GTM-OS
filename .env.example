# GTM Agent OS — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env — it is gitignored.

# --- The Hog API (two credentials required) ---
# Sent as X-Access-Key and X-Secret-Key headers on every request.
# Get these from https://developer.thehog.ai
HOG_ACCESS_KEY=your_hog_access_key_here
HOG_SECRET_KEY=your_hog_secret_key_here

# --- Google Sheets (pipeline output) ---
# Spreadsheet ID from the sheet URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Path to the Google service-account JSON key file (the file itself is gitignored).
GOOGLE_SERVICE_ACCOUNT_PATH=service-account.json

# --- Anthropic (optional) ---
# Not needed when running inside Claude Code. Add only if you build a custom
# frontend/integration that calls the Claude API directly.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
